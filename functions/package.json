{
  "name": "laqta-functions",
  "description": "Firebase Cloud Functions for Laqta",
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "test": "firebase emulators:exec --project demo-no-project --config ../firebase.emulators.json --only firestore \"node --test --test-concurrency=1 \\\"./test/*.test.js\\\"\"",
    "test:functions": "npm run test",
    "test:rules": "npm run test"
  },
  "private": true,
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.5.0",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.0.0"
  }
}
