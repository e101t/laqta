rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024 && // 5MB max
             request.resource.contentType.matches('image/.*');
    }
    
    function isValidVideo() {
      return request.resource.size < 50 * 1024 * 1024 && // 50MB max
             request.resource.contentType.matches('video/.*');
    }
    
    function isValidDocument() {
      return request.resource.size < 20 * 1024 * 1024 && // 20MB max
             (
               request.resource.contentType.matches('application/pdf') ||
               request.resource.contentType.matches('application/msword') ||
               request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\..*') ||
               request.resource.contentType.matches('application/vnd\\.ms-powerpoint.*') ||
               request.resource.contentType.matches('application/vnd\\.ms-excel.*') ||
               request.resource.contentType.matches('text/plain')
             );
    }
    
    function isBookingParticipant(bookingId) {
      let booking = firestore.get(/databases/$(database)/documents/bookings/$(bookingId));
      return isSignedIn() &&
             booking != null &&
             booking.data != null &&
             (
               request.auth.uid == booking.data.customerId ||
               request.auth.uid == booking.data.photographerId
             );
    }
    
    function isChatParticipant(chatId) {
      let chat = firestore.get(/databases/$(database)/documents/chats/$(chatId));
      return isSignedIn() &&
             chat != null &&
             chat.data != null &&
             request.auth.uid in chat.data.participants;
    }
    
    // User profile photos
    match /users/{userId}/profile/{fileName} {
      allow read: if true; // Public read
      allow write: if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId);
    }
    
    // Photographer portfolios
    match /photographers/{photographerId}/portfolio/{fileName} {
      allow read: if true; // Public read
      allow write: if isOwner(photographerId) && isValidImage();
      allow delete: if isOwner(photographerId);
    }
    
    // Booking attachments
    match /bookings/{bookingId}/attachments/{fileName} {
      allow read: if isBookingParticipant(bookingId);
      allow write: if isBookingParticipant(bookingId) && isValidImage();
      allow delete: if isBookingParticipant(bookingId);
    }
    
    // Chat images
    match /chat_images/{chatId}/{fileName} {
      allow read: if isChatParticipant(chatId);
      allow write: if isChatParticipant(chatId) && isValidImage();
      allow delete: if isChatParticipant(chatId);
    }
    
    // Chat videos
    match /chat_videos/{chatId}/{fileName} {
      allow read: if isChatParticipant(chatId);
      allow write: if isChatParticipant(chatId) && isValidVideo();
      allow delete: if isChatParticipant(chatId);
    }
    
    // Chat documents
    match /chat_documents/{chatId}/{fileName} {
      allow read: if isChatParticipant(chatId);
      allow write: if isChatParticipant(chatId) && isValidDocument();
      allow delete: if isChatParticipant(chatId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
