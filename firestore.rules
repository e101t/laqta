rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function isValidRole(role) {
      return role in ['customer', 'photographer'];
    }

    function hasOnlyKeys(data, keys) {
      return data.keys().hasOnly(keys);
    }

    function hasValidRoleIfPresent(data) {
      return !('role' in data) || isValidRole(data.role);
    }

    function canWriteReview(bookingId, photographerId) {
      let booking = get(/databases/$(database)/documents/bookings/$(bookingId));
      return booking != null &&
             booking.data != null &&
             booking.data.status == 'done' &&
             booking.data.customerId == request.auth.uid &&
             booking.data.photographerId == photographerId;
    }

    function isParticipant(participants) {
      return isSignedIn() && request.auth.uid in participants;
    }

    function isChatParticipant(chatId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/chats/$(chatId)) &&
             isParticipant(
               get(/databases/$(database)/documents/chats/$(chatId)).data.participants
             );
    }

    function isValidBookingStatus(status) {
      return status in ['pending', 'confirmed', 'rejected', 'done', 'canceled'];
    }

    function bookingUpdateKeysAllowed() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'status',
        'notes',
        'location',
        'chatId',
        'updatedAt',
        'date',
        'time',
        'duration',
        'type'
      ]);
    }

    function chatUpdateKeysAllowed() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'lastMessageAt'
      ]);
    }

    function storyViewUpdateAllowed() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'views'
      ]);
    }

    function reelCounterUpdateAllowed() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'views',
        'likes',
        'comments',
        'shares'
      ]);
    }

    function publicUserKeys() {
      return [
        'name',
        'username',
        'usernameLower',
        'photoUrl',
        'governorate',
        'gender',
        'age',
        'birthYear',
        'role',
        'profileCompleted',
        'over18Confirmed',
        'lang',
        'lastSeen',
        'createdAt',
        'updatedAt'
      ];
    }

    function userKeys() {
      return [
        'uid',
        'name',
        'email',
        'phone',
        'photoUrl',
        'role',
        'username',
        'usernameLower',
        'gender',
        'birthYear',
        'age',
        'governorate',
        'lang',
        'profileCompleted',
        'over18Confirmed',
        'blockedUsers',
        'interests',
        'fcmToken',
        'lastSeen',
        'createdAt',
        'updatedAt'
      ];
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) &&
                    hasOnlyKeys(request.resource.data, userKeys()) &&
                    hasValidRoleIfPresent(request.resource.data);
      allow update: if isOwner(userId) &&
                    hasOnlyKeys(request.resource.data, userKeys()) &&
                    hasValidRoleIfPresent(request.resource.data);
      allow delete: if isOwner(userId);

      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users_public/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) &&
                    hasOnlyKeys(request.resource.data, publicUserKeys()) &&
                    hasValidRoleIfPresent(request.resource.data);
      allow update: if isOwner(userId) &&
                    hasOnlyKeys(request.resource.data, publicUserKeys()) &&
                    hasValidRoleIfPresent(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /photographers/{photographerId} {
      allow read: if true;
      allow create: if isOwner(photographerId);
      allow update: if isOwner(photographerId);
      allow delete: if isOwner(photographerId);
    }

    match /portfolios/{portfolioId} {
      allow read: if true;
      allow create: if isSignedIn() &&
                      request.resource.data.photographerId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
                              resource.data.photographerId == request.auth.uid;
    }

    match /availabilities/{availabilityId} {
      allow read: if true;
      allow create: if isSignedIn() &&
                      request.resource.data.photographerId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
                              resource.data.photographerId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() &&
                    (request.auth.uid == resource.data.customerId ||
                     request.auth.uid == resource.data.photographerId);
      allow create: if isSignedIn() &&
                      request.resource.data.customerId == request.auth.uid &&
                      isNonEmptyString(request.resource.data.photographerId) &&
                      isValidBookingStatus(request.resource.data.status);
      allow update: if isSignedIn() &&
                      (request.auth.uid == resource.data.customerId ||
                       request.auth.uid == resource.data.photographerId) &&
                      request.resource.data.customerId == resource.data.customerId &&
                      request.resource.data.photographerId == resource.data.photographerId &&
                      request.resource.data.price == resource.data.price &&
                      request.resource.data.currency == resource.data.currency &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      isValidBookingStatus(request.resource.data.status) &&
                      bookingUpdateKeysAllowed();
      allow delete: if isOwner(resource.data.customerId);
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && isParticipant(resource.data.participants);
      allow create: if isSignedIn() &&
                      request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() &&
                      isParticipant(resource.data.participants) &&
                      request.resource.data.participants == resource.data.participants &&
                      chatUpdateKeysAllowed();
      allow delete: if isSignedIn() && isParticipant(resource.data.participants);

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId) &&
                        request.resource.data.senderId == request.auth.uid &&
                        request.resource.data.chatId == chatId;
        allow update: if isChatParticipant(chatId) &&
                        request.resource.data.senderId == resource.data.senderId &&
                        request.resource.data.chatId == resource.data.chatId &&
                        request.resource.data.content == resource.data.content &&
                        request.resource.data.type == resource.data.type &&
                        request.resource.data.createdAt == resource.data.createdAt &&
                        request.auth.uid in request.resource.data.seenBy &&
                        request.resource.data.seenBy.hasAll(resource.data.seenBy);
        allow delete: if isChatParticipant(chatId);
      }
    }

    match /stories/{storyId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.photographerId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
        resource.data.photographerId == request.auth.uid;
      allow update: if isSignedIn() && storyViewUpdateAllowed();
    }

    match /reels/{reelId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.photographerId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
        resource.data.photographerId == request.auth.uid;
      allow update: if isSignedIn() && reelCounterUpdateAllowed();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() &&
                      request.resource.data.userId == request.auth.uid &&
                      isNonEmptyString(request.resource.data.reelId);
      allow update: if isSignedIn() &&
                      request.auth.uid == resource.data.userId;
      allow delete: if isSignedIn() &&
                      request.auth.uid == resource.data.userId;
    }

    match /offers/{offerId} {
      allow read: if true;
      allow create: if isSignedIn() &&
                      request.resource.data.photographerId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
                              resource.data.photographerId == request.auth.uid;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() &&
                      request.resource.data.reviewerId == request.auth.uid &&
                      request.resource.data.rating is int &&
                      request.resource.data.rating >= 1 &&
                      request.resource.data.rating <= 5 &&
                      isNonEmptyString(request.resource.data.bookingId) &&
                      isNonEmptyString(request.resource.data.targetId) &&
                      canWriteReview(
                        request.resource.data.bookingId,
                        request.resource.data.targetId
                      );
      allow update: if isOwner(resource.data.reviewerId) &&
                      request.resource.data.bookingId == resource.data.bookingId &&
                      request.resource.data.targetId == resource.data.targetId &&
                      request.resource.data.reviewerId == resource.data.reviewerId;
      allow delete: if isOwner(resource.data.reviewerId);
    }

    match /favorites/{favoriteId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() &&
                      request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }

    match /following/{followId} {
      allow read: if isSignedIn() &&
                    resource.data.followerId == request.auth.uid;
      allow create: if isSignedIn() &&
                      request.resource.data.followerId == request.auth.uid &&
                      isNonEmptyString(request.resource.data.followingId);
      allow delete: if isSignedIn() &&
                      resource.data.followerId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow read: if false;
      allow create: if isSignedIn() &&
                      request.resource.data.reporterId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() &&
                    resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
                              resource.data.userId == request.auth.uid;
      allow create: if false;
    }

    match /user_achievements/{achievementId} {
      allow read: if isSignedIn() &&
                    resource.data.userId == request.auth.uid;
      allow create, update, delete: if isSignedIn() &&
                                      request.resource.data.userId == request.auth.uid;
    }

    match /loyalty_points/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
