rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isPhotographer() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'photographer';
    }
    
    function isCustomer() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'customer';
    }
    
    function isParticipant(participants) {
      return isSignedIn() && request.auth.uid in participants;
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function canWriteReview(bookingId, photographerId) {
      let booking = get(/databases/$(database)/documents/bookings/$(bookingId));
      return booking != null &&
             booking.data != null &&
             booking.data.status == 'done' &&
             booking.data.customerId == request.auth.uid &&
             booking.data.photographerId == photographerId;
    }
    
    function isChatParticipant(chatId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/chats/$(chatId)) &&
             isParticipant(
               get(/databases/$(database)/documents/chats/$(chatId)).data.participants
             );
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // Private user data (move sensitive fields here)
      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Photographers collection
    match /photographers/{photographerId} {
      allow read: if true; // Public read for browsing
      allow create: if isOwner(photographerId) && isPhotographer();
      allow update: if isOwner(photographerId) && isPhotographer();
      allow delete: if isOwner(photographerId);
    }
    
    // Portfolios collection
    match /portfolios/{portfolioId} {
      allow read: if true; // Public read
      allow write: if isSignedIn() && 
                     request.resource.data.photographerId == request.auth.uid &&
                     isPhotographer();
    }
    
    // Availabilities collection
    match /availabilities/{availabilityId} {
      allow read: if true; // Public read for booking
      allow write: if isSignedIn() &&
                     request.resource.data.photographerId == request.auth.uid &&
                     isPhotographer();
    }
    
    // Bookings collection
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && 
                    (request.auth.uid == resource.data.customerId ||
                     request.auth.uid == resource.data.photographerId);
      allow create: if isSignedIn() && isCustomer() &&
                      request.resource.data.customerId == request.auth.uid;
      allow update: if isSignedIn() &&
                      (request.auth.uid == resource.data.customerId ||
                       request.auth.uid == resource.data.photographerId) &&
                      request.resource.data.customerId == resource.data.customerId &&
                      request.resource.data.photographerId == resource.data.photographerId;
      allow delete: if isOwner(resource.data.customerId);
    }
    
    // Chats collection
    match /chats/{chatId} {
      allow read: if isSignedIn() && isParticipant(resource.data.participants);
      allow create: if isSignedIn() &&
                      request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() &&
                      isParticipant(resource.data.participants) &&
                      request.resource.data.participants == resource.data.participants;
      allow delete: if isSignedIn() && isParticipant(resource.data.participants);
      
      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId) &&
                        request.resource.data.senderId == request.auth.uid &&
                        request.resource.data.chatId == chatId;
        allow update: if isChatParticipant(chatId) &&
                        request.auth.uid == resource.data.senderId;
        allow delete: if isChatParticipant(chatId);
      }
    }
    
    // Offers collection
    match /offers/{offerId} {
      allow read: if true; // Public read
      allow write: if isSignedIn() &&
                     request.resource.data.photographerId == request.auth.uid &&
                     isPhotographer();
    }
    
    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if true; // Public read
      allow create: if isSignedIn() &&
                      request.resource.data.reviewerId == request.auth.uid &&
                      isNonEmptyString(request.resource.data.bookingId) &&
                      isNonEmptyString(request.resource.data.targetId) &&
                      canWriteReview(
                        request.resource.data.bookingId,
                        request.resource.data.targetId
                      );
      allow update: if isOwner(resource.data.reviewerId);
      allow delete: if isOwner(resource.data.reviewerId);
    }
    
    // Favorites collection
    match /favorites/{favoriteId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }
    
    // Reports collection
    match /reports/{reportId} {
      allow read: if false; // Admin only
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if false; // Server-only
    }
  }
}
